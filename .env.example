# Local PostgreSQL — individual connection parameters
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=stock_tracker
LOCAL_DB_USER=your_postgres_username
LOCAL_DB_PASSWORD=your_postgres_password

# Neon cloud PostgreSQL — connection string (copy directly from Neon dashboard)
NEON_DB_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/stock_tracker?sslmode=require

# Financial Modeling Prep (https://financialmodelingprep.com)
FMP_API_KEY=your_fmp_api_key_here

# Anthropic Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gmail SMTP — the account used to SEND reports
GMAIL_USER=your_sender_gmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# The email address that RECEIVES the reports
REPORT_RECIPIENT_EMAIL=atomicdawg125@yahoo.com

# Local folder containing manually-saved earnings transcripts (outside the repo)
# Expected layout: {TRANSCRIPTS_DIR}/{TICKER}/{YEAR}_Q{N}.md
TRANSCRIPTS_DIR=/Users/brandon/Documents/earnings_transcripts
